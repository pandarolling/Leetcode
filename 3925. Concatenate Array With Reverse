class Solution {
public:
    vector<int> concatWithReverse(vector<int>& nums) {
        int n = nums.size();
        cout<<n<<endl;
        vector<int> ans;
        int i ;
        for(i =0; i < n; i++){
            ans.push_back(nums[i]);
        }

        for(i =0; i < n; i++){
            ans.push_back(nums[n-i-1]);
        }

        return ans;
    }
};
