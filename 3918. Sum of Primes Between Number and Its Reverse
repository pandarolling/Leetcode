class Solution {
public:

    bool isprime(int n){
        if(n ==1 || n== 0){
            return false;
        }

        for(int i = 2; i <= sqrt(n); i++){
            if(n % i ==0){
                return false;
            }
        }
        return true;
    }
    
    int revof(int n){
        int r= 0;
        while(n != 0){
            r *= 10;
            r += n%10;
            n/= 10;
        }
        return r;
    }

    int primein(int lo, int hi){
        int sum = 0;
       for(int i = lo; i <= hi; i++){
           if(isprime(i)){
               sum += i;
           }
       } 
        return sum;
    }

    
    int sumOfPrimesInRange(int n) {
        int r = revof(n);
        int sum = primein(min(n, r) , max(n,r));

        return sum;
    }
};
